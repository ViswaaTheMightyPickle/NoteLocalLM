# Copy this to .env and adjust values as needed.
# Docker Compose reads .env automatically.

# URLs used inside the Docker network (leave as-is for Docker Compose)
QDRANT_URL=http://qdrant:6333
OLLAMA_URL=http://ollama:11434

# For local dev outside Docker, override these:
# QDRANT_URL=http://localhost:6333
# OLLAMA_URL=http://localhost:11434

# SQLite database path (inside the backend container)
SQLITE_PATH=/data/app.db

# Root data directory mounted into the backend container
DATA_DIR=/data

# HuggingFace model cache (persisted via Docker volume)
HF_HOME=/root/.cache/huggingface

# Frontend → Backend URL (inside Docker network)
BACKEND_URL=http://backend:8000
# For local dev: BACKEND_URL=http://localhost:8000

# LLM runtime tuning
# Larger context improves long-document answers but uses more VRAM/RAM.
LLM_CONTEXT_TOKENS=16384
LLM_KEEP_ALIVE=30m

# Ollama tuning for Docker GPU runs.
# Keep a single runner so large context windows do not multiply KV-cache memory.
OLLAMA_NUM_PARALLEL=1
# Reserve VRAM headroom on Docker Desktop / WSL2 if the GPU OOMs.
# OLLAMA_GPU_OVERHEAD=2147483648
